# Copy this file to .env and fill in your values

# PostgreSQL connection URL
# For Docker: the default below works out of the box
# For local dev without Docker: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://cinematch:cinematch@db:5432/cinematch

# (Optional) TMDB API key for movie posters and plot summaries
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# (Optional) Override the API base URL baked into the frontend at build time
# Default: /api (correct for Docker — nginx proxies /api to the backend)
# Change only if your backend is hosted at a different URL
VITE_API_URL=/api
